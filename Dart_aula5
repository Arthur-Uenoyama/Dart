abstract class Animal {
  String fazerBarulho();
}

class Gato implements Animal {
  @override
  String fazerBarulho() {
    return 'Miau!';
  }
}

void main() {
  final gato = Gato();
  print('O gato diz: ${gato.fazerBarulho()}');
}

