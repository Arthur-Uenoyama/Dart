import 'package:flutter/material.dart';

void main() {
  runApp(MainApp());
}

class MainApp extends StatelessWidget {
  MainApp({super.key});

  var linguagens = ['HTML', 'CSS', 'JavaScript'];

  Widget filhos() {
    List<Widget> itens = [];

    for (var linguagem in linguagens) {
      itens.add(Text(linguagem));
    }

    return Column(
      children: itens,
    );
  }

  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      home: Scaffold(
        body: Center(
          child: filhos(),
        ),
      ),
    );
  }
}

