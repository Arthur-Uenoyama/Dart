class Celular {
  final String marca;
  final String modelo;
  int nivelBateria;

  Celular(this.marca, this.modelo, this.nivelBateria);

  void mostrarStatus() {
    print('Marca: $marca');
    print('Modelo: $modelo');
    print('Nível da Bateria: $nivelBateria%');
  }
}

void main() {
  var meuCelular = Celular(
    "Motorola",
    "G34",
    15,
  );
  meuCelular.mostrarStatus();
}
