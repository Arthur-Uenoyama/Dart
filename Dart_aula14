import 'package:flutter/material.dart';

void main() {
  runApp(const MainApp());
}

class MainApp extends StatelessWidget {
  const MainApp({super.key});

  double media(List<double> notas) {
    if (notas.isEmpty) return 0.0;

    double soma = 0.0;

    for (var nota in notas) {
      soma += nota;
    }

    return soma / notas.length;
  }

  double maiorNota(List<double> notas) {
    if (notas.isEmpty) return 0.0;

    double maior = notas[0];

    for (var nota in notas) {
      if (nota > maior) {
        maior = nota;
      }
    }

    return maior;
  }

  double menorNota(List<double> notas) {
    if (notas.isEmpty) return 0.0;

    double menor = notas[0];

    for (var nota in notas) {
      if (nota < menor) {
        menor = nota;
      }
    }

    return menor;
  }

  @override
  Widget build(BuildContext context) {
    var notas = [5.0, 6.5, 8.2];

    var resultadoMedia = media(notas);
    var maior = maiorNota(notas);
    var menor = menorNota(notas);

    var msg = '''
Média: ${resultadoMedia.toStringAsFixed(2)}

Maior Nota: ${maior.toStringAsFixed(2)}

Menor Nota: ${menor.toStringAsFixed(2)}
''';

    return MaterialApp(
      home: Scaffold(
        appBar: AppBar(
          title: const Text('Exercício 1'),
          backgroundColor: Colors.blue,
          foregroundColor: Colors.white,
        ),
        body: Center(
          child: Text(
            msg,
            textAlign: TextAlign.center,
            style: const TextStyle(fontSize: 20),
          ),
        ),
      ),
    );
  }
}


//ex2
import 'package:flutter/material.dart';

void main() {
  runApp(const MainApp());
}

class MainApp extends StatefulWidget {
  const MainApp({super.key});

  @override
  State<MainApp> createState() => _MainAppState();
}

class _MainAppState extends State<MainApp> {
  final TextEditingController _controller = TextEditingController();

  final List<double> _notas = [];

  double calcularMedia() {
    if (_notas.isEmpty) return 0.0;

    double soma = _notas.reduce((a, b) => a + b);

    return soma / _notas.length;
  }

  double maiorNota() {
    if (_notas.isEmpty) return 0.0;

    return _notas.reduce(
      (a, b) => a > b ? a : b,
    );
  }

  double menorNota() {
    if (_notas.isEmpty) return 0.0;

    return _notas.reduce(
      (a, b) => a < b ? a : b,
    );
  }

  void adicionarNota() {
    if (_controller.text.isEmpty) return;

    setState(() {
      double novaNota = double.parse(_controller.text);

      _notas.add(novaNota);

      _controller.clear();
    });
  }

  @override
  Widget build(BuildContext context) {
    double media = calcularMedia();

    double soma =
        _notas.isEmpty ? 0.0 : _notas.reduce((a, b) => a + b);

    double maior = maiorNota();

    double menor = menorNota();

    return MaterialApp(
      home: Scaffold(
        appBar: AppBar(
          title: const Text('Calculadora de Médias'),
          backgroundColor: Colors.blue,
          foregroundColor: Colors.white,
        ),
        body: Padding(
          padding: const EdgeInsets.all(16.0),
          child: Column(
            children: [
              Row(
                children: [
                  Expanded(
                    child: TextFormField(
                      controller: _controller,
                      keyboardType: TextInputType.number,
                      decoration: const InputDecoration(
                        labelText: 'Digite uma nota',
                        hintText: 'Ex: 7.5',
                        border: OutlineInputBorder(),
                      ),
                    ),
                  ),

                  const SizedBox(width: 8),

                  ElevatedButton(
                    onPressed: adicionarNota,
                    child: const Text('Adicionar'),
                  ),
                ],
              ),

              const SizedBox(height: 20),

              Card(
                elevation: 4,
                child: Padding(
                  padding: const EdgeInsets.all(16.0),
                  child: Column(
                    children: [
                      Text(
                        'Total de Notas: ${_notas.length}',
                        style: const TextStyle(fontSize: 18),
                      ),

                      const SizedBox(height: 10),

                      Text(
                        'Soma Total: ${soma.toStringAsFixed(2)}',
                        style: const TextStyle(fontSize: 18),
                      ),

                      const SizedBox(height: 10),

                      Text(
                        'Média: ${media.toStringAsFixed(2)}',
                        style: const TextStyle(fontSize: 18),
                      ),

                      const SizedBox(height: 10),

                      Text(
                        'Maior Nota: ${maior.toStringAsFixed(2)}',
                        style: const TextStyle(fontSize: 18),
                      ),

                      const SizedBox(height: 10),

                      Text(
                        'Menor Nota: ${menor.toStringAsFixed(2)}',
                        style: const TextStyle(fontSize: 18),
                      ),
                    ],
                  ),
                ),
              ),

              const SizedBox(height: 20),

              Expanded(
                child: ListView.builder(
                  itemCount: _notas.length,
                  itemBuilder: (context, index) {
                    return ListTile(
                      leading: const Icon(Icons.school),
                      title: Text(
                        'Nota ${index + 1}: ${_notas[index].toStringAsFixed(2)}',
                      ),
                    );
                  },
                ),
              ),
            ],
          ),
        ),
      ),
    );
  }
}
