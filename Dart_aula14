import 'package:flutter/material.dart';

void main() {
  runApp(MainApp());
}

class MainApp extends StatelessWidget {
  const MainApp({super.key});

  double media(List<double> notas) {
    if (notas.isEmpty) return 0.0;

    double soma = 0.0;

    for (var nota in notas) {
      soma += nota;
    }

    return soma / notas.length;
  }

  double maiorNota(List<double> notas) {
    if (notas.isEmpty) return 0.0;

    double maior = notas[0];

    for (var nota in notas) {
      if (nota > maior) {
        maior = nota;
      }
    }

    return maior;
  }

  double menorNota(List<double> notas) {
    if (notas.isEmpty) return 0.0;

    double menor = notas[0];

    for (var nota in notas) {
      if (nota < menor) {
        menor = nota;
      }
    }

    return menor;
  }

  @override
  Widget build(BuildContext context) {
    var notas = [5.0, 6.5, 8.2];

    var msg =
        "Média: ${media(notas).toStringAsFixed(2)}\n"
        "Maior nota: ${maiorNota(notas)}\n"
        "Menor nota: ${menorNota(notas)}";

    return MaterialApp(
      home: Scaffold(
        body: Center(
          child: Text(msg),
        ),
      ),
    );
  }
}

